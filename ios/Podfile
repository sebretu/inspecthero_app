# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously during install.
# If you want to disable it, uncomment the following line.
# ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

# Dynamic help for Flutter Root and Podhelper
def find_podhelper
  local_helper = File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
  return local_helper if File.exist?(local_helper)

  # Fallback for CI environments where it might not be generated yet
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      if matches
        sdk_helper = File.join(matches[1].strip, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
        return sdk_helper if File.exist?(sdk_helper)
      end
    end
  end
  
  # Last resort: try environment variable
  if ENV['FLUTTER_ROOT']
    sdk_helper = File.join(ENV['FLUTTER_ROOT'], 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
    return sdk_helper if File.exist?(sdk_helper)
  end
  
  local_helper # Return local path and let it fail if still not found
end

require find_podhelper

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      # Fix for code signing issues on CI
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
    end
  end
end
